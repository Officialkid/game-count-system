# ============================================================================
# GAME COUNT SYSTEM - Neon/Prisma Environment Template
# ============================================================================
# Copy this file to .env.local and fill in your actual values.
# This file reflects the active target backend architecture:
# Next.js + Node.js + Neon + Prisma.
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------
# Neon pooled connection string for Prisma runtime queries.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=15"

# Optional direct connection string for migrations or admin tooling.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&connect_timeout=15"

# ----------------------------------------------------------------------------
# APPLICATION URLS
# ----------------------------------------------------------------------------
# Production-first Vercel defaults. For local development, use .env.local with
# localhost values instead.
APP_URL="https://game-count-system.vercel.app"
NEXT_PUBLIC_APP_URL="https://game-count-system.vercel.app"
NEXT_PUBLIC_BASE_URL="https://game-count-system.vercel.app"
NEXT_PUBLIC_API_BASE_URL="https://game-count-system.vercel.app"
NEXT_PUBLIC_URL="https://game-count-system.vercel.app"

# ----------------------------------------------------------------------------
# OPERATIONS / SCHEDULING / MONITORING
# ----------------------------------------------------------------------------
CRON_SECRET="replace_with_a_long_random_secret"
ADMIN_CLEANUP_SECRET="replace_with_a_long_random_secret"
SENTRY_DSN=""

# ----------------------------------------------------------------------------
# OPTIONAL APPLICATION SETTINGS
# ----------------------------------------------------------------------------
NODE_ENV="development"
LOG_LEVEL="debug"
