# Local development example for the Prisma/Neon migration target
APP_URL=http://localhost:3002
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_BASE_URL=http://localhost:3002
NEXT_PUBLIC_API_BASE_URL=http://localhost:3002
NEXT_PUBLIC_URL=http://localhost:3002

# Neon pooled runtime connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=15"

# Optional direct connection string for migrations
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require&connect_timeout=15"

CRON_SECRET=replace_with_a_long_random_secret
ADMIN_CLEANUP_SECRET=replace_with_a_long_random_secret
NODE_ENV=development
