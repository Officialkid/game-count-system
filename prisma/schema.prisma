generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventMode {
  quick
  camp
  advanced
}

enum EventStatus {
  draft
  active
  completed
  archived
}

enum ScoringMode {
  continuous
  daily
}

enum TokenType {
  admin
  scorer
  viewer
}

enum ScoreSourceType {
  manual
  quick_add
  bulk_entry
  import
  sync
  correction
}

enum AuditAction {
  create
  update
  delete
  archive
  finalize
  reopen
  lock_day
  unlock_day
  submit_score
  bulk_submit_score
  export
  regenerate_token
}

model Organization {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  events    Event[]
  templates EventTemplate[]
}

model Event {
  id                     String        @id @default(cuid())
  name                   String
  slug                   String?       @unique
  eventMode              EventMode
  eventStatus            EventStatus   @default(draft)
  scoringMode            ScoringMode   @default(continuous)
  numberOfDays           Int           @default(1)
  requiresAuthentication Boolean       @default(false)
  legacyStatus           String?       @db.VarChar(32)
  themeColor             String?       @db.VarChar(32)
  logoUrl                String?
  startAt                DateTime
  endAt                  DateTime
  autoCleanupAt          DateTime?
  isFinalized            Boolean       @default(false)
  finalizedAt            DateTime?
  archivedAt             DateTime?
  createdBy              String?
  organizationId         String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  organization           Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  eventDays              EventDay[]
  teams                  Team[]
  scores                 Score[]
  tokens                 EventToken[]
  auditLogs              AuditLog[]
  scoreBatches           ScoreBatch[]

  @@index([eventStatus, createdAt])
  @@index([eventMode, startAt])
  @@index([organizationId])
}

model EventToken {
  id        String    @id @default(cuid())
  eventId    String
  tokenType  TokenType
  tokenHash  String    @unique
  plainToken String?
  isActive   Boolean   @default(true)
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, tokenType])
  @@index([eventId, tokenType])
}

model EventDay {
  id        String    @id @default(cuid())
  eventId    String
  dayNumber  Int
  label      String?
  date       DateTime?
  isLocked   Boolean   @default(false)
  lockedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  event      Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scores     Score[]

  @@unique([eventId, dayNumber])
  @@index([eventId, dayNumber])
}

model Team {
  id         String    @id @default(cuid())
  eventId     String
  name        String
  color       String    @db.VarChar(32)
  avatarUrl   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scores      Score[]

  @@index([eventId, createdAt])
  @@unique([eventId, name])
}

model ScoreBatch {
  id                String          @id @default(cuid())
  eventId            String
  category           String?
  submissionKey      String?         @unique
  sourceType         ScoreSourceType @default(bulk_entry)
  createdByTokenType TokenType?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  event              Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scores             Score[]

  @@index([eventId, createdAt])
}

model Score {
  id                String          @id @default(cuid())
  eventId            String
  teamId             String
  eventDayId         String?
  scoreBatchId       String?
  category           String?         @db.VarChar(120)
  points             Int
  penalty            Int?
  bonus              Int?
  notes              String?
  sourceType         ScoreSourceType @default(manual)
  submissionKey      String?         @unique
  createdByTokenType TokenType?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  event              Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  team               Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  eventDay           EventDay?       @relation(fields: [eventDayId], references: [id], onDelete: SetNull)
  scoreBatch         ScoreBatch?     @relation(fields: [scoreBatchId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
  @@index([teamId, createdAt])
  @@index([eventDayId, createdAt])
}

model AuditLog {
  id             String      @id @default(cuid())
  eventId         String
  actorTokenType  TokenType?
  action          AuditAction
  entityType      String
  entityId        String?
  payload         Json?
  createdAt       DateTime    @default(now())
  event           Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@index([action, createdAt])
}

model EventTemplate {
  id             String        @id @default(cuid())
  organizationId String?
  name           String
  description    String?
  eventMode      EventMode
  scoringMode    ScoringMode
  numberOfDays   Int           @default(1)
  themeColor     String?       @db.VarChar(32)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
}

model WaitlistSignup {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
